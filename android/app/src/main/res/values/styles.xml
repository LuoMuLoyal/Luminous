<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="LaunchTheme" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@drawable/launch_screen</item>
        <item name="windowSplashScreenBackground">@color/launch_background_color</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_wordmark_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/launch_icon_background_color</item>
        <item name="postSplashScreenTheme">@style/NormalTheme</item>
        <item name="android:statusBarColor">@color/launch_status_bar_color</item>
        <item name="android:navigationBarColor">@color/launch_navigation_bar_color</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_screen</item>
        <item name="android:statusBarColor">@color/launch_status_bar_color</item>
        <item name="android:navigationBarColor">@color/launch_navigation_bar_color</item>
    </style>
</resources>
