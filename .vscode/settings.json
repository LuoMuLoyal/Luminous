{
  "commitlint.preferBundledLibraries": true,
  "commitlint.log.enabled": false,
  "commitlint.config.extend.rules": {
    "header-max-length": [1, "always", 120],
    "scope-case": [1, "always", "lower-case"],
    "subject-empty": [1, "never"],
    "type-case": [1, "always", "lower-case"],
    "type-empty": [1, "never"],
    "type-enum": [
      1,
      "always",
      [
        "feat",
        "fix",
        "docs",
        "style",
        "refactor",
        "perf",
        "test",
        "build",
        "ci",
        "chore",
        "revert"
      ]
    ],
    "subject-max-length": [1, "always", 100]
  },
  "git-commit-message-editor.autoFillTypeFromBranchName.enabled": true,
  "git-commit-message-editor.conventionalCommits.enabled": true
}
